# Copy to `.env` and fill values. Expo reads any var prefixed with
# EXPO_PUBLIC_ at build time and exposes it to your JS bundle.
#
# WARNING — these values ship inside your app binary. Use TEST keys only
# (ohms_test_*). For production, your app should call YOUR backend
# (which holds the live key in a secrets manager), never api.ohm.doctor
# directly. See examples/nextjs-server-action for the proxy pattern.

# ─────────────────────────────────────────────────────────────────────
# OHM auth — required
# ─────────────────────────────────────────────────────────────────────

# Test-mode key — safe to ship in the bundle for development builds.
EXPO_PUBLIC_OHM_API_KEY=ohms_test_xxxxxxxxxxxxxxxxxxxx

# Override only for self-host or staging. Default is api.ohm.doctor.
EXPO_PUBLIC_OHM_BASE_URL=https://api.ohm.doctor

# ─────────────────────────────────────────────────────────────────────
# Schema slugs — must match what you Published in Studio
# (See examples/hospital-integration/README.md, Step 1.)
# ─────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_OHM_VITALS_SLUG=inpatient-vitals
EXPO_PUBLIC_OHM_DOCTOR_NOTE_SLUG=inpatient-doctor-note
EXPO_PUBLIC_OHM_NURSE_SHIFT_SLUG=nurse-shift-handover

# ─────────────────────────────────────────────────────────────────────
# Optional — Async jobs webhook
# ─────────────────────────────────────────────────────────────────────
# Public HTTPS URL on YOUR backend that receives signed POST callbacks
# when async jobs reach a terminal state. Leave blank to use polling
# from the device (the demo's default mode for the Async tab).
# EXPO_PUBLIC_OHM_WEBHOOK_URL=https://your-backend.example.com/ohm-callback
