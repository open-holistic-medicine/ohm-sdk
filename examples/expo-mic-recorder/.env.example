# ────────────────────────────────────────────────────────────────────
# OHM Expo mic-recorder demo
# Copy to `.env`, fill values, restart with `npx expo start --clear`.
# ────────────────────────────────────────────────────────────────────

# Test-mode key — safe to ship in dev bundles. Mint at studio.ohm.doctor.
# Live keys (ohms_live_*) are REJECTED in RN bundles by default.
EXPO_PUBLIC_OHM_TEST_KEY=ohms_test_replace_me

# Slug of a published Studio API. Default mirrors the snippet.
EXPO_PUBLIC_OHM_API_SLUG=opd-clinic
