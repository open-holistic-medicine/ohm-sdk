# Copy this to `.env` in this folder and fill in the live values.
# Never commit `.env` itself — only this `.env.example` template.
#
# Used by:
#   • probe.ts                                          (sanity check via SDK)
#   • The Next.js / Express backend proxy you write     (Step 3 in README)

# ─────────────────────────────────────────────────────────────────────
# OHM credentials
# ─────────────────────────────────────────────────────────────────────

# Test-mode key for local development. Mint at:
#   https://studio.ohm.doctor → Project → Keys → "+ New key"
# These are safe to share with your dev team. Test calls do not bill.
OHM_API_KEY=ohms_test_xxxxxxxxxxxxxxxxxxxx

# Live-mode key for your backend ONLY. NEVER bundle in mobile / browser.
# Set in your backend's secrets manager and read at runtime.
# OHM_API_KEY=ohms_live_xxxxxxxxxxxxxxxxxxxx

# OHM API base URL. Override only if you self-host.
OHM_BASE_URL=https://api.ohm.doctor

# ─────────────────────────────────────────────────────────────────────
# Schema slugs — must match what you Published in Studio
# ─────────────────────────────────────────────────────────────────────
# Defaults match the schema folder names. Override any of these if you
# picked different slugs in Studio's "+ New API" dialog (e.g.
# `inpatient-vital` singular).
OHM_VITALS_SLUG=inpatient-vitals
OHM_DOCTOR_NOTE_SLUG=inpatient-doctor-note
OHM_NURSE_SHIFT_SLUG=nurse-shift-handover
