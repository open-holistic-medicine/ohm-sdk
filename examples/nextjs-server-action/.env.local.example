# Copy to .env.local. Mint a key from https://studio.ohm.doctor → Keys.
# Use a test-mode key (ohms_test_*) for development.
OHM_API_KEY=ohms_test_replace_me

# Optional — your API base URL if self-hosting OHM.
# OHM_BASE_URL=https://api.ohm.doctor

# The slug of a published API in your OHM Studio project.
# Default matches the snippet in app/actions.ts.
OHM_API_SLUG=opd-clinic
