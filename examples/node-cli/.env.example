# ────────────────────────────────────────────────────────────────────
# OHM Node CLI — required env
# Copy this file to `.env` and fill in your values, then `npm install`.
# ────────────────────────────────────────────────────────────────────

# Mint a key at studio.ohm.doctor → Keys → New key.
# Test keys (ohms_test_*) and live keys (ohms_live_*) both work in Node.
OHM_API_KEY=ohms_test_replace_me

# Optional. Override only for self-host or staging.
# OHM_BASE_URL=https://api.ohm.doctor
