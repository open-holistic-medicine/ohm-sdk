# ────────────────────────────────────────────────────────────────────
# OHM streaming demo — Next.js
# Copy to `.env.local`, fill values, then `npm install && npm run dev`.
# ────────────────────────────────────────────────────────────────────

# Mint a key at studio.ohm.doctor → Keys → New key.
# Live keys (ohms_live_*) are safe HERE because the key stays in the
# Next.js server runtime — it never ships to the browser bundle.
OHM_API_KEY=ohms_test_replace_me

# Slug of a published Studio API. Default mirrors the snippet.
OHM_API_SLUG=opd-clinic

# Optional — override base URL only when self-hosting OHM.
# OHM_BASE_URL=https://api.ohm.doctor
