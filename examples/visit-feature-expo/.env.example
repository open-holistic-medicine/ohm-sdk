# Copy to .env. Use a TEST key (live keys are blocked from RN bundles).
# Mint one at https://studio.ohm.doctor → Keys → New key → Test mode.
EXPO_PUBLIC_OHM_TEST_KEY=ohms_test_replace_me

# A published API in your Studio project. Default works if you cloned
# the OPD Prescription starter and named it "opd-clinic".
EXPO_PUBLIC_OHM_API_SLUG=opd-clinic
