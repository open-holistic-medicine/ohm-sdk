# ────────────────────────────────────────────────────────────────────
# OHM webhook receiver — required env
# Copy this file to `.env` and fill in your values, then `npm install`.
# ────────────────────────────────────────────────────────────────────

# The signing secret is shown ONCE when you create the webhook in Studio
# (Studio → API → Settings → Webhooks → + Add). Paste it here.
# OHM uses this to sign every event body with HMAC-SHA256.
OHM_WEBHOOK_SECRET=replace_me

# Optional — port the receiver listens on. Default 4040.
# PORT=4040
